// OPTIONAL compile-time fallback. The normal path is to leave this alone and
// provision over USB-serial from the web-flasher (writes NVS). These #defines are
// only used when NVS is empty — handy if you'd rather bake credentials in.
// Copy this file to config.h and fill in your values. config.h is gitignored.
#pragma once

#define WIFI_SSID  "your-wifi"
#define WIFI_PASS  "your-password"

// Server BASE url only (no path). The firmware appends /frame.bin and
// /firmware.bin itself. LAN IP or mDNS name, plain HTTP, no trailing slash.
#define SERVER_BASE_URL "http://192.168.1.50:8090"
